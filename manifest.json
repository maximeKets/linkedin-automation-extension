{
  "manifest_version": 3,
  "name": "LinkedIn Stealth Automator",
  "version": "0.1.0",
  "description": "Automatise l'envoi d'invitations LinkedIn avec notes personnalisées depuis une page de recherche.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "32": "public/icons/icon-32.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["src/main.ts"],
      "run_at": "document_idle"
    }
  ]
}
